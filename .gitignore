# ─────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─────────────────────────────────────────────
# Джерельні PDF та HTML (81 МБ, лише для читання)
# Відновлюються вручну із Zotero / посилань у .bib
# ─────────────────────────────────────────────
docs/sources/files/

# ─────────────────────────────────────────────
# Зкомпільовані Word-документи (build artifacts)
# Відновлюються через: bash build/scripts/build_docx.sh
# Виняток: reference.docx — шаблон стилів для pandoc (12 КБ)
# ─────────────────────────────────────────────
build/*.docx
!build/reference.docx

# ─────────────────────────────────────────────
# Тимчасові резервні копії master.md
# ─────────────────────────────────────────────
build/master_backup_*.md

# ─────────────────────────────────────────────
# PNG-діаграми Розділу 2 — генеруються з .puml
# Відновлюються через: bash build/render_plantuml.sh
# Виняток: вихідні .puml файли — зберігаємо
# ─────────────────────────────────────────────
docs/chapter2/images/*.png

# ─────────────────────────────────────────────
# Build-артефакти (JSON-мапи цитувань, аудит тощо)
# Відновлюються скриптом build_master_md.py
# ─────────────────────────────────────────────
outputs/

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# ─────────────────────────────────────────────
# Редактори
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# Skills runtime (відновлюється через: make install-skills)
# skills-lock.json комітити – це lockfile
# ─────────────────────────────────────────────
.agents/

# ─────────────────────────────────────────────
# Node.js / Frontend
# ─────────────────────────────────────────────
node_modules/
app/frontend/dist/
app/frontend/*.tsbuildinfo
app/backend/.coverage

# ─────────────────────────────────────────────
# Секрети – ніколи не комітити
# ─────────────────────────────────────────────
.env

# ─────────────────────────────────────────────
# Python-застосунок (app/backend)
# ─────────────────────────────────────────────
app/backend/.venv/
app/backend/.mypy_cache/
app/backend/.ruff_cache/
app/backend/.pytest_cache/

# ─────────────────────────────────────────────
# Різне
# ─────────────────────────────────────────────
*.log
*.tmp
