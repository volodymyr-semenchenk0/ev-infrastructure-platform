# ─────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─────────────────────────────────────────────
# Coursework report — text, images, sources, build tools
# Kept locally / in Google Drive, not in this repo
# ─────────────────────────────────────────────
docs/
build/

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# ─────────────────────────────────────────────
# Editors
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# Skills runtime (restored via: make install-skills)
# skills-lock.json is a lockfile — commit it
# ─────────────────────────────────────────────
.agents/

# ─────────────────────────────────────────────
# Node.js / Frontend
# ─────────────────────────────────────────────
node_modules/
app/frontend/dist/
app/frontend/*.tsbuildinfo
app/frontend/coverage/
app/frontend/.env.local
app/frontend/.env.*.local

# ─────────────────────────────────────────────
# Playwright e2e artifacts
# ─────────────────────────────────────────────
app/frontend/playwright-report/
app/frontend/test-results/

# ─────────────────────────────────────────────
# Secrets — never commit
# ─────────────────────────────────────────────
.env

# ─────────────────────────────────────────────
# Python app (app/backend)
# ─────────────────────────────────────────────
app/backend/.venv/
app/backend/.mypy_cache/
app/backend/.ruff_cache/
app/backend/.pytest_cache/
app/backend/.coverage
app/backend/htmlcov/

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
*.log
*.tmp
outputs/

# Google Drive sync artifacts
.tmp.driveupload/
.tmp.drivedownload/
