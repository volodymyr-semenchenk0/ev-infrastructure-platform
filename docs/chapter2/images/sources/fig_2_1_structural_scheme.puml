@startuml
' Рис. 2.1. Структурна схема системи: трирівнева клієнт-серверна архітектура з REST API
skinparam shadowing false
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 12
skinparam rectangle {
    BackgroundColor #f5f5f5
    BorderColor #333333
    BorderThickness 1.2
}
skinparam database {
    BackgroundColor #eaeaea
    BorderColor #333333
}
skinparam cloud {
    BackgroundColor #fafafa
    BorderColor #555555
}

rectangle "Презентаційний шар" as L1 {
    rectangle "Клієнтська підсистема\n(вебзастосунок у браузері)" as Client
}

rectangle "Шар бізнес-логіки" as L2 {
    rectangle "Серверна підсистема" as Server {
        rectangle "REST-контролери" as Ctrl
        rectangle "Сервісний шар:\nFAHPCalculator,\nTOPSISRanker,\nMonteCarloAnalyzer" as Svc
        rectangle "ETL-модуль\nзовнішніх даних" as ETL
    }
}

rectangle "Шар доступу до даних" as L3 {
    database "Реляційна СУБД\nз просторовим\nрозширенням" as DB
}

rectangle "Зовнішні джерела даних" as EXT {
    cloud "OpenStreetMap" as OSM
    cloud "Open Charge Map" as OCM
    cloud "Державна\nслужба статистики" as DSU
}

Client -down-> Ctrl : HTTPS\n(REST API)
Ctrl -down-> Svc : виклики\nсервісів
Svc -down-> DB : ORM /\nwire protocol
ETL -right-> OSM : Overpass /\nREST
ETL -right-> OCM : REST API
ETL -right-> DSU : CSV-вивантаження
ETL -down-> DB : запис\nнормалізованих\nданих

@enduml
