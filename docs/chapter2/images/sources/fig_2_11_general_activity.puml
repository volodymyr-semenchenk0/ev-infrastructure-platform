@startuml
' Рис. 2.11. Діаграма активностей загального сценарію функціонування системи
skinparam shadowing false
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 9
skinparam pageMargin 3
skinparam activity {
    BackgroundColor #f5f5f5
    BorderColor #333333
}
skinparam swimlane {
    BackgroundColor #fafafa
    BorderColor #333333
}

|Користувач (ОПР)|
start
:Відкрити систему;\nобрати профіль ОПР;

|Серверна підсистема|
:Завантажити профіль,\nкритерії та матрицю Ã;

|Клієнтська підсистема|
:Відобразити матрицю;\nautofill нижньотрикутної частини;

|Користувач (ОПР)|
:Ввести / підтвердити\nматрицю Ã та запустити\nобчислення;

|Серверна підсистема|
:Розрахувати ваги (FAHP)\nта ранжування (TOPSIS);\nзберегти результати;

|Клієнтська підсистема|
:Відобразити ранжування\nна карті та у таблиці;

|Користувач (ОПР)|
if (Аналіз чутливості?) then (так)
    |Серверна підсистема|
    :Виконати Монте-Карло;\nзберегти результати;
    |Клієнтська підсистема|
    :Відобразити частотні\nдіаграми та довірчі інтервали;
endif

|Користувач (ОПР)|
:Запустити експорт\n(JSON / CSV);
|Серверна підсистема|
:Сформувати файл експорту;
|Клієнтська підсистема|
:Завантажити файл\nкористувачеві;
stop

@enduml
