@startuml
' Рис. 2.11. Діаграма розгортання системи
skinparam shadowing false
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 11
skinparam ArrowColor #333333
skinparam ArrowFontColor #333333
skinparam linetype ortho
skinparam nodesep 25
skinparam ranksep 45
skinparam node {
    BackgroundColor #f5f5f5
    BorderColor #333333
    BorderThickness 1.2
}
skinparam component {
    BackgroundColor #fafafa
    BorderColor #555555
}

node "Клієнтський пристрій" <<device>> as Client {
    component "Клієнтська підсистема" as ClientApp
}

node "Сервер вебзастосунку" <<device>> as AppNode {
    component "Сервіс оркестрації" as AppOrch
    component "Обчислювальне ядро\n(FAHP / TOPSIS / Монте-Карло)" as AppCore
    component "Компонент завантаження\nвхідних даних" as AppETL
    AppOrch -[hidden]right- AppCore
    AppCore -[hidden]right- AppETL
}

node "Сервер бази даних" <<device>> as DBNode {
    component "Реляційна СУБД" as DB
}

node "Зовнішні джерела даних" as Ext

Client -- AppNode : <<HTTPS>> REST API
AppNode -- DBNode : <<протокол СУБД / TLS>>
AppNode -- Ext : <<HTTPS>>

@enduml
