@startuml
' Рис. 2.12. Діаграма активностей загального сценарію функціонування системи
skinparam shadowing false
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 11
skinparam activity {
    BackgroundColor #f5f5f5
    BorderColor #333333
}
skinparam swimlane {
    BackgroundColor #fafafa
    BorderColor #333333
}

|Користувач (ОПР)|
start
:Відкрити систему;
:Обрати профіль ОПР\n(municipal / investor);

|Клієнтська підсистема|
:GET /api/profiles/{id};

|Серверна підсистема|
:Підвантажити критерії\nта збережену матрицю Ã;

|Сховище|
:SELECT критерії,\nSELECT pairwise_matrices;

|Клієнтська підсистема|
:Відобразити завантажену\nматрицю попарних порівнянь;

|Користувач (ОПР)|
if (Коригувати матрицю?) then (так)
    :Інтерактивне введення\nверхньотрикутної частини Ã;
    |Клієнтська підсистема|
    :Автозаповнити нижньотрикутну\nчастину оберненими TFN;
endif

|Користувач (ОПР)|
:Запустити повний\nобчислювальний цикл;

|Клієнтська підсистема|
:POST /api/evaluations\n{profileId, Ã};

|Серверна підсистема|
:Алгоритм 2.1 (FAHP):\nобчислити вектор ваг W;
:Алгоритм 2.2 (TOPSIS):\nобчислити ранжування;

|Сховище|
:INSERT evaluation_run,\nINSERT ranking_items;

|Клієнтська підсистема|
:Відобразити ранжування\nна карті та таблиці;

|Користувач (ОПР)|
if (Аналіз чутливості?) then (так)
    |Клієнтська підсистема|
    :POST /api/evaluations/\n{id}/sensitivity;
    |Серверна підсистема|
    :Алгоритм 2.3 (Монте-Карло):\nматриця стабільності P;
    |Сховище|
    :INSERT sensitivity_record;
    |Клієнтська підсистема|
    :Відобразити частотні\nдіаграми top-k\nта довірчі інтервали;
endif

|Користувач (ОПР)|
if (Порівняти з другим профілем?) then (так)
    :Повторити обчислення\nдля іншого профілю;
    |Серверна підсистема|
    :Обчислити рангову\nкореляцію Спірмена ρ;
    |Клієнтська підсистема|
    :Відобразити порівняльну\nтаблицю;
endif

|Користувач (ОПР)|
:Експортувати результати\n(JSON / CSV);

|Клієнтська підсистема|
:GET /api/evaluations/\n{id}/export;

|Серверна підсистема|
:Сформувати документ\nекспорту;

|Клієнтська підсистема|
:Завантажити файл\nкористувачеві;
stop

@enduml
