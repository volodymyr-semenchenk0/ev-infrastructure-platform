# ─────────────────────────────────────────────
# Backend / Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ev_charging

# ─────────────────────────────────────────────
# CORS — comma-separated allow-list of frontend origins.
# Production: add the Vercel domain, e.g.
#   CORS_ORIGINS=https://ev-charging-dss.vercel.app
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# Supabase (продакшн; локально не потрібно)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ─────────────────────────────────────────────
# PostgreSQL (Docker Compose)
# ─────────────────────────────────────────────
POSTGRES_DB=ev_charging
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
